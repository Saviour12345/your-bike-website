{
  "name": "@max/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared, theme-driven component library for the Max portfolio. Consumed as TS source via Next transpilePackages.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./motion": "./src/motion/index.ts",
    "./seo": "./src/seo/index.ts",
    "./server": "./src/forms/server/handle-lead.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@max/config": "*",
    "@max/tokens": "*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
