# Your Bike Website — environment variables
# Copy to .env.local for development. Set the same keys on Vercel for Production + Preview.

# ── Live Google reviews (src/lib/google-places.ts) ───────────────────────────
# SECRET — server-only. Google Cloud API key with "Places API (New)" enabled.
Places_API=

# Optional override of the Google Place ID for your shop listing.
# GOOGLE_PLACE_ID=

# ── Live refurbished inventory — CycleSoftware (src/lib/cyclesoftware/) ──────
# SECRET — server-only. CS Connect Basic Auth credentials for Articledata V4.
CYCLESOFTWARE_API_USER=
CYCLESOFTWARE_API_PASSWORD=
# CYCLESOFTWARE_STORE_ID=
# CYCLESOFTWARE_REVALIDATE_SECONDS=900

# ── Cron protection (api/cron/sync-inventory) ────────────────────────────────
CRON_SECRET=

# ── Live Instagram feed (src/lib/instagram.ts) ───────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ── Public config (safe to expose; NEXT_PUBLIC_*) ────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://your-bike-website.vercel.app
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GOOGLE_PLACE_ID=
# NEXT_PUBLIC_GOOGLE_REVIEW_URL=
# NEXT_PUBLIC_INSTAGRAM_HANDLE=yourbikewebsite
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourbikewebsite/
